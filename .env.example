# Copy this file to .env and fill in your API keys.
# Only the keys for platforms you want to scrape are required.

# YouTube Data API v3 (free, 10k units/day)
# https://console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Reddit OAuth2 app credentials (free, read-only script app)
# https://www.reddit.com/prefs/apps → "script" type app
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=influencer-radar/1.0

# Apify API token — required for TikTok, Twitter/X, and Instagram scraping
# https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_api_token_here
